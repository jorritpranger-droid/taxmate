{
  "manifest_version": 3,
  "name": "TaxMate for Gmail",
  "version": "1.0",
  "description": "Analyse emails for tax deductions directly inside Gmail",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
